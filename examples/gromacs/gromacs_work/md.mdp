; md.mdp - production MD, ~20 ps smoke test (fixed template — change only named parameters)
integrator           = md
nsteps               = 250000         ; 500 ps @ dt=0.002
dt                   = 0.002
; output control -- MUST write a trajectory for rms/gyrate analysis
nstxout-compressed   = 500            ; md.xtc every 1 ps  (needed by gmx rms / gmx gyrate)
compressed-x-grps    = System
nstenergy            = 500            ; md.edr            (needed by gmx energy)
nstlog               = 500
; neighbor search / electrostatics
cutoff-scheme        = Verlet
coulombtype          = PME
rcoulomb             = 1.0
rvdw                 = 1.0
pbc                  = xyz
; bond constraints
constraints          = h-bonds
constraint-algorithm = lincs
; temperature coupling
tcoupl               = V-rescale
tc-grps              = Protein Non-Protein
tau_t                = 0.1     0.1
ref_t                = 325     325
; pressure coupling
pcoupl               = Parrinello-Rahman
pcoupltype           = isotropic
tau_p                = 2.0
ref_p                = 800.0
compressibility      = 4.5e-5
; continue from NPT (velocities present); no restraints in production
gen_vel              = no
continuation         = yes
