; nvt.mdp - NVT equilibration, ~20 ps (fixed template — change only named parameters)
integrator           = md
nsteps               = 10000          ; 20 ps @ dt=0.002
dt                   = 0.002
; output control
nstenergy            = 500
nstlog               = 500
; neighbor search / electrostatics
cutoff-scheme        = Verlet
coulombtype          = PME
rcoulomb             = 1.0
rvdw                 = 1.0
pbc                  = xyz
; bond constraints (REQUIRED for dt=0.002 stability)
constraints          = h-bonds
constraint-algorithm = lincs
; temperature coupling
tcoupl               = V-rescale
tc-grps              = Protein Non-Protein
tau_t                = 0.1     0.1
ref_t                = 300     300
; no pressure coupling in NVT
pcoupl               = no
; generate starting velocities (no velocities after EM)
gen_vel              = yes
gen_temp             = 300
gen_seed             = -1
continuation         = no
; restrain protein heavy atoms during equilibration
define               = -DPOSRES
